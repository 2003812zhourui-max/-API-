# Copy this file to .env, then fill in your own values.
# Do not commit .env. It is already ignored by .gitignore.

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Recommended: paste the direct Bitable /base/ URL that contains ?table=tblxxx.
FEISHU_BITABLE_URL=https://your-domain.feishu.cn/base/bascnxxxxxxxx?table=tblxxxxxxxx

# Or set these two instead of FEISHU_BITABLE_URL.
# FEISHU_APP_TOKEN=bascnxxxxxxxx
# FEISHU_TABLE_ID=tblxxxxxxxx

# Upload source and sheet.
FEISHU_KPI_FILE=C:\Users\Administrator\-API-\output\kpi\delivery_kpi_20260608.xlsx
FEISHU_SHEET_NAME=波次号去重统计

# For a display-only table, set 1 to clear existing rows before uploading.
FEISHU_CLEAR_TABLE=0
